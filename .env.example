# -----------------------------------------
#  IBM watsonx.ai Configuration
# -----------------------------------------

# Your IBM Cloud API key  (IAM -> Manage -> Access -> API Keys)
IBM_API_KEY=your_ibm_api_key_here

# watsonx.ai Project ID  (watsonx.ai -> Projects -> <your project> -> Manage -> General)
IBM_PROJECT_ID=your_project_id_here

# Regional service URL  (choose the region closest to you)
#   Dallas   : https://us-south.ml.cloud.ibm.com
#   London   : https://eu-gb.ml.cloud.ibm.com
#   Frankfurt: https://eu-de.ml.cloud.ibm.com
#   Tokyo    : https://jp-tok.ml.cloud.ibm.com
#   Sydney   : https://au-syd.ml.cloud.ibm.com
IBM_REGION_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite model ID
#   Recommended: ibm/granite-3-8b-instruct
#   Alternative: ibm/granite-13b-instruct-v2
IBM_MODEL_ID=ibm/granite-3-8b-instruct

# -----------------------------------------
#  Flask Configuration
# -----------------------------------------
FLASK_SECRET_KEY=change_this_to_a_random_secret_string
FLASK_ENV=production
FLASK_DEBUG=False